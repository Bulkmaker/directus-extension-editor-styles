    "type": "git",
    "url": "git+https://github.com/Bulkmaker/directus-extension-editor-styles.git"
  },
  "devDependencies": {
    "@directus/extensions-sdk": "^12.0.0",
    "typescript": "^5.3.0"
  }
}
